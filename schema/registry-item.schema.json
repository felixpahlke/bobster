{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/felixpahlke/bobster/main/schema/registry-item.schema.json",
  "title": "Bobster registry item",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "type", "version", "description", "tags", "files", "entry"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "type": {
      "enum": ["skill", "rule", "mode"]
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 12
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "enum": ["stable", "experimental", "deprecated"]
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "not": {
          "anyOf": [
            { "pattern": "^/" },
            { "pattern": "(^|/)\\.\\.(/|$)" }
          ]
        }
      }
    },
    "entry": {
      "type": "string"
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string" },
        "path": { "type": "string" },
        "ref": { "type": "string" },
        "sha": { "type": "string" },
        "importedAt": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
